        "url": "https://ghfast.top/https://raw.githubusercontent.com/nekolsd/sing-geosite/rule-set/github.srs",
        "http_client": "download_update",
        "update_interval": "24h"
      },
      {
        "type": "remote",
        "tag": "telegram",
        "path": "./RuleProviders/telegram.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/nekolsd/sing-geosite/rule-set/telegram.srs",
        "http_client": "download_update",
        "update_interval": "24h"
      },
      {
        "type": "remote",
        "tag": "geolocation-!cn@cn",
        "path": "./RuleProviders/geolocation-!cn@cn.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/nekolsd/sing-geosite/rule-set/geolocation-!cn@cn.srs",
        "http_client": "download_update",
        "update_interval": "24h"
      },
      {
        "type": "remote",
        "tag": "cn@!cn",
        "path": "./RuleProviders/cn@!cn.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/nekolsd/sing-geosite/rule-set/cn@!cn.srs",
        "http_client": "download_update",

        "url": "https://ghfast.top/https://raw.githubusercontent.com/nekolsd/sing-geosite/rule-set/cn.srs",
        "http_client": "download_update",
        "update_interval": "24h"
      },
      {
        "type": "remote",
        "tag": "geoip-google",
        "path": "./RuleProviders/geoip-google.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/nekolsd/geoip/release/srs/google.srs",
        "http_client": "download_update",
        "update_interval": "24h"
      },
      {
        "type": "remote",
        "tag": "geoip-telegram",
        "path": "./RuleProviders/geoip-telegram.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/nekolsd/geoip/release/srs/telegram.srs",
        "http_client": "download_update",
        "update_interval": "24h"
      },
      {
        "type": "remote",
        "tag": "geoip-cn",
        "path": "./RuleProviders/geoip-cn.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/nekolsd/geoip/release/srs/cn.srs",
        "http_client": "download_update",
        "update_interval": "24h"
      },
      {
        "type": "local",
        "tag": "reject-domain",
        "path": "./RuleProviders/reject-domain.json"
      },
      {
        "type": "local",
        "tag": "direct-domain",
        "path": "./RuleProviders/direct-domain.json"
      },
      {
        "type": "local",
        "tag": "proxy-domain",
        "path": "./RuleProviders/proxy-domain.json"
      },
      {
        "type": "local",
        "tag": "emby-domain",

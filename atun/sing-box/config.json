    "final": "Proxy",
    "auto_detect_interface": true,
    "default_domain_resolver": "direct-dns",
    "default_domain_match_strategy": "prefer_fqdn"
  },
  "services": [
    {
      "type": "api",
      "tag": "sing-box dashboard",
      "listen": "127.0.0.1",
      "listen_port": 9901,
      "secret": "singbox",
      "dashboard": {
        "enabled": true,
        "path": "./Dashboard/nativeboard",
        "download_url": "https://github.com/SagerNet/sing-box-dashboard/archive/refs/heads/gh-pages.zip",
        "http_client": "download_proxy",
        "update_interval": "7d"
      }
    }
  ],
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "./cache.db",
      "store_dns": true
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9909",
      "external_ui": "./Dashboard/zashboard",
      "external_ui_download_url": "https://github.com/Zephyruso/zashboard/archive/refs/heads/gh-pages.zip",
      "external_ui_http_client": "download_proxy",
      "secret": "singbox"
    },
    "urltest_unified_delay": true
  }
}